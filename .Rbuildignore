^docs$
^dev$
^\.github$
^LICENSE\.md$
^.*\.Rproj$
^\.Rproj\.user$
^scratchpad$
^\.git$
^CLAUDE\.md$
^_pkgdown\.yml$
^site$
^pkgdown$
^\.claude$
^cran-comments\.md$
^CRAN-SUBMISSION$
# Vignette precompute sources: the .Rmd.orig files are evaluated locally by
# vignettes/precompute.R and their baked .Rmd output is what ships. Keep the
# sources and the build script out of the tarball.
^vignettes/.*\.Rmd\.orig$
^vignettes/precompute\.R$
